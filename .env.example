# Base de datos (Railway Postgres)
DATABASE_URL=postgresql://user:password@host:5432/railway

# JWT — generá uno largo y aleatorio para producción
JWT_SECRET=cambia_este_secreto_en_produccion_min_32_chars

# Cloudflare R2
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=tu_r2_access_key
R2_SECRET_ACCESS_KEY=tu_r2_secret_key
R2_BUCKET=alfalca-files

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
